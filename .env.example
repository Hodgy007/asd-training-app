# ─── Database ────────────────────────────────────────────────────────────────
# Supabase: use the pooled connection URL for DATABASE_URL
# and the direct (non-pooled) URL for DIRECT_URL (required for Prisma migrations)
DATABASE_URL="postgresql://username:password@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://username:password@host:5432/postgres"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="your-32-char-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth (SSO) ───────────────────────────────────────────────────────
# Create at https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Microsoft Azure AD (SSO) ─────────────────────────────────────────────────
# Create at https://portal.azure.com → Azure Active Directory → App registrations
# Redirect URI: http://localhost:3000/api/auth/callback/azure-ad
# signInAudience: AzureADandPersonalMicrosoftAccount (for personal + work accounts)
AZURE_AD_CLIENT_ID="your-azure-app-client-id"
AZURE_AD_CLIENT_SECRET="your-azure-client-secret"
AZURE_AD_TENANT_ID="common"

# ─── AI (Google Gemini) ───────────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"
